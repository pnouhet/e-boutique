{% extends 'base.html.twig' %}
{% block title %}Créer un compte — Zone Instru{% endblock %}

{% block body %}
<div class="max-w-sm mx-auto py-8">
    <h1 class="text-2xl font-bold tracking-tight text-black/85 mb-8 text-center">
        Créer un compte
    </h1>

    {{ form_start(registrationForm, {attr: {class: 'space-y-4'}}) }}

    <div>
        {{ form_label(registrationForm.name, 'Nom', {label_attr: {class: 'block text-xs uppercase tracking-widest text-black/50 mb-1.5'}}) }}
        {{ form_widget(registrationForm.name, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black/10'}}) }}
        {{ form_errors(registrationForm.name) }}
    </div>

    <div>
        {{ form_label(registrationForm.email, 'E-mail', {label_attr: {class: 'block text-xs uppercase tracking-widest text-black/50 mb-1.5'}}) }}
        {{ form_widget(registrationForm.email, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black/10'}}) }}
        {{ form_errors(registrationForm.email) }}
    </div>

    <div>
        {{ form_label(registrationForm.plainPassword, 'Mot de passe', {label_attr: {class: 'block text-xs uppercase tracking-widest text-black/50 mb-1.5'}}) }}
        {{ form_widget(registrationForm.plainPassword, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black/10'}}) }}
        {{ form_errors(registrationForm.plainPassword) }}
    </div>

    <div class="border-t border-gray-100 pt-4">
        <h2 class="text-sm font-semibold text-black/70 mb-4">Adresse de livraison</h2>
        <div class="space-y-4">
            <div>
                {{ form_label(registrationForm.address, 'Adresse', {label_attr: {class: 'block text-xs uppercase tracking-widest text-black/50 mb-1.5'}}) }}
                {{ form_widget(registrationForm.address, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black/10'}}) }}
                {{ form_errors(registrationForm.address) }}
            </div>
            <div class="grid grid-cols-3 gap-3">
                <div>
                    {{ form_label(registrationForm.cp, 'Code postal', {label_attr: {class: 'block text-xs uppercase tracking-widest text-black/50 mb-1.5'}}) }}
                    {{ form_widget(registrationForm.cp, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black/10'}}) }}
                    {{ form_errors(registrationForm.cp) }}
                </div>
                <div class="col-span-2">
                    {{ form_label(registrationForm.city, 'Ville', {label_attr: {class: 'block text-xs uppercase tracking-widest text-black/50 mb-1.5'}}) }}
                    {{ form_widget(registrationForm.city, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black/10'}}) }}
                    {{ form_errors(registrationForm.city) }}
                </div>
            </div>
            <div>
                {{ form_label(registrationForm.country, 'Pays', {label_attr: {class: 'block text-xs uppercase tracking-widest text-black/50 mb-1.5'}}) }}
                {{ form_widget(registrationForm.country, {attr: {class: 'w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black/10'}}) }}
                {{ form_errors(registrationForm.country) }}
            </div>
        </div>
    </div>

    <button type="submit"
            class="w-full bg-black text-white rounded-xl py-3 text-sm font-semibold
                   hover:bg-black/90 transition-colors">
        S'inscrire
    </button>

    {{ form_end(registrationForm) }}

    <p class="text-center text-sm text-black/40 mt-6">
        Déjà un compte ?
        <a href="{{ path('app_login') }}"
           class="text-black/70 hover:text-black transition-colors font-medium">
            Se connecter
        </a>
    </p>
</div>
{% endblock %}
